DATABASE_URL=postgres://lettura:lettura@127.0.0.1:5436/lettura
JWT_SECRET=<generate-a-random-secret-at-least-32-characters>
LISTEN_ADDR=0.0.0.0:3330
INDEX_PATH=/data/tantivy

# Image storage: "local" or "oss"
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=/data/storage

# OSS (S3-compatible) - only needed when STORAGE_TYPE=oss
# OSS_ENDPOINT=https://s3.amazonaws.com
# OSS_REGION=us-east-1
# OSS_BUCKET=lettura-images
# OSS_ACCESS_KEY=your-access-key
# OSS_SECRET_KEY=your-secret-key
# OSS_PUBLIC_URL=https://cdn.example.com/lettura-images

# CORS: comma-separated origins. REQUIRED in production (LETTURA_PRODUCTION=true).
# Development default is "*" but production must specify explicit origins.
# CORS_ORIGINS=https://example.com,chrome-extension://abc123

# Production mode: enables stricter security defaults
# LETTURA_PRODUCTION=true

# Registration: disabled by default for safety. Set to "false" to allow new users.
# LETTURA_DISABLE_REGISTRATION=true

# Site rules directory (YAML files named <domain>.yaml)
# LETTURA_SITE_CONFIGS_PATH=/data/site-configs

# Render fallback (needs image built with RENDERING=1 and chromium installed)
# LETTURA_RENDERING_ENABLED=auto           # auto | true | false
# LETTURA_CHROMIUM_PATH=/usr/bin/chromium  # override auto-detection
# LETTURA_RENDER_CONCURRENCY=2
# LETTURA_RENDER_TIMEOUT_MS=15000

# Metrics: set a bearer token to enable /metrics endpoint (disabled by default)
# LETTURA_METRICS_BEARER_TOKEN=your-secret-metrics-token
