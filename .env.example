DATABASE_URL=postgres://lettura:lettura@127.0.0.1:5432/lettura
JWT_SECRET=change-me-in-production-use-at-least-32-chars
LISTEN_ADDR=0.0.0.0:3330
INDEX_PATH=/data/tantivy

# Image storage: "local" or "oss"
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=/data/storage

# OSS (S3-compatible) - only needed when STORAGE_TYPE=oss
# OSS_ENDPOINT=https://s3.amazonaws.com
# OSS_REGION=us-east-1
# OSS_BUCKET=lettura-images
# OSS_ACCESS_KEY=your-access-key
# OSS_SECRET_KEY=your-secret-key
# OSS_PUBLIC_URL=https://cdn.example.com/lettura-images

# CORS: comma-separated origins, or "*" for any (default: *)
# CORS_ORIGINS=https://example.com,chrome-extension://abc123
