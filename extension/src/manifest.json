{
  "manifest_version": 3,
  "name": "Lettura",
  "version": "1.2.0",
  "description": "Save articles to your Lettura instance",
  "permissions": ["activeTab", "contextMenus", "storage"],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/index.ts"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}