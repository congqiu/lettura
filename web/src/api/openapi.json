{
  "openapi": "3.1.0",
  "info": {
    "title": "Lettura API",
    "description": "Lettura is a wallabag-inspired read-it-later service. Endpoints below are stable; unannotated routes exist but their schema is not yet machine-readable.",
    "license": {
      "name": ""
    },
    "version": "1.0.0"
  },
  "paths": {
    "/api/health": {
      "get": {
        "tags": [
          "health"
        ],
        "operationId": "health_check",
        "responses": {
          "200": {
            "description": "Service is healthy or degraded (DB up)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          },
          "503": {
            "description": "Database unreachable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/tags": {
      "get": {
        "tags": [
          "tags"
        ],
        "operationId": "list_tags",
        "responses": {
          "200": {
            "description": "All tags the user has created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Tag"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid auth"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": [
          "status",
          "db",
          "search"
        ],
        "properties": {
          "db": {
            "type": "string",
            "description": "Database probe result."
          },
          "search": {
            "type": "string",
            "description": "Search index probe result."
          },
          "status": {
            "type": "string",
            "description": "Overall service status: \"ok\" | \"degraded\" | \"error\"."
          }
        }
      },
      "Tag": {
        "type": "object",
        "required": [
          "id",
          "user_id",
          "label",
          "slug",
          "created_at"
        ],
        "properties": {
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "label": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "user_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "health",
      "description": "Service liveness and readiness"
    },
    {
      "name": "tags",
      "description": "User-defined tags applied to entries"
    }
  ]
}
